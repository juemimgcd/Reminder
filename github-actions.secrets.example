# GitHub Actions repository secrets
# Required:
DEPLOY_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----

# Optional:
# You can also put these in Repository secrets, but host/user/port
# are usually easier to maintain in Repository variables.
DEPLOY_HOST=your-server-ip-or-domain
DEPLOY_PORT=22
DEPLOY_USER=your-server-user
DEPLOY_PASSWORD=your-server-password-if-not-using-ssh-key

# GitHub Actions repository variables
# Recommended:
DEPLOY_HOST=your-server-ip-or-domain
DEPLOY_PORT=22
DEPLOY_USER=your-server-user
DEPLOY_APP_DIR=/opt/reminder
DEPLOY_BRANCH=master
DEPLOY_ENABLE_NGINX_SYNC=1
