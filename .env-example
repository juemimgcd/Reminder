# Copy this file to .env before running the project locally.
# Docker Compose will also read these variables and override DATABASE_URL for the app container.

PROJECT_NAME=Agentic RAG Assistant
VERSION=0.1.0
DESCRIPTION=一个基于 FastAPI 的 Agentic RAG 私有知识助手后端项目
API_PREFIX=/api/v1
PYTHON_VERSION=3.12
PIP_INDEX_URL=https://pypi.org/simple
PIP_EXTRA_INDEX_URL=

DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/agentic

STORAGE_DIR=./storage
RAW_FILE_DIR=./storage/raw
ALLOWED_EXTENSIONS=[".pdf",".txt",".md"]
MAX_FILE_SIZE=10485760

EMBEDDING_MODEL_NAME=BAAI/bge-m3
CHROMA_COLLECTION_NAME=document_chunks
CHROMA_PERSIST_DIR=./storage/vector_store

DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0.0

JWT_SECRET=change-this-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=agentic
POSTGRES_PORT=5432
