# Copy this file to .env before running the project locally.
# Docker Compose will also read these variables and override DATABASE_URL for the app container.

PROJECT_NAME=Agentic RAG Assistant
VERSION=0.1.0
DESCRIPTION=一个基于 FastAPI 的 Agentic RAG 私有知识助手后端项目
LOG_LEVEL=INFO
PYTHON_VERSION=3.12
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
APP_PORT=8000
APP_HOST_PORT=8000
UVICORN_WORKERS=1
WAIT_FOR_TIMEOUT_SECONDS=180

CORS_ALLOWED_ORIGINS=["http://www.mneme.com.cn","https://www.mneme.com.cn","http://mneme.com.cn","https://mneme.com.cn"]
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/agentic

STORAGE_DIR=./storage
RAW_FILE_DIR=./storage/raw
ALLOWED_EXTENSIONS=[".pdf",".txt",".md",".docx",".pptx",".xlsx",".xls",".csv",".json",".xml",".html",".htm",".epub"]
MAX_FILE_SIZE=10485760

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_PATH=
EMBEDDING_CACHE_DIR=./storage/model_cache/sentence_transformers
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_PRELOAD_ON_STARTUP=false
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_TIMEOUT=600
HF_TOKEN=
VECTOR_BACKEND=milvus
GRAPH_BACKEND=neo4j
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=document_chunks
MILVUS_INDEX_TYPE=FLAT
MILVUS_METRIC_TYPE=IP
MILVUS_SEARCH_PARAMS={"metric_type":"IP"}
MILVUS_CONSISTENCY_LEVEL=Strong
MILVUS_DROP_OLD=false
NEO4J_ENABLED=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-in-production
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=20
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474

DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0.0

JWT_SECRET=change-this-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=agentic
POSTGRES_PORT=5432

REDIS_PORT=6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_INDEX_QUEUE=document_index
CELERY_WORKER_CONCURRENCY=1
CELERY_LOG_LEVEL=INFO

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_CPU_LIMIT=2.0
MILVUS_MEMORY_LIMIT=4g

INDEX_VECTOR_BATCH_SIZE=64
RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX=10
INDEX_SUBMIT_RATE_LIMIT_MAX=20
CHAT_QUERY_RATE_LIMIT_MAX=30

EXTERNAL_RETRY_MAX_ATTEMPTS=3
EXTERNAL_RETRY_BASE_DELAY_SECONDS=0.5
EXTERNAL_RETRY_MAX_DELAY_SECONDS=4.0

CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
