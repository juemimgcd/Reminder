PROJECT_NAME=Reminder
VERSION=0.1.0
DESCRIPTION=Reminder production environment
LOG_LEVEL=INFO

APP_IMAGE_REPOSITORY=ghcr.io/juemimgcd/reminder
APP_IMAGE_TAG=
APP_IMAGE_PULL_POLICY=always

PYTHON_VERSION=3.12
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=

APP_PORT=8000
APP_HOST_PORT=127.0.0.1:8000
UVICORN_WORKERS=2
# Empty keeps Docker startup lightweight. Set to "vector" to start milvus + etcd + minio.
COMPOSE_PROFILES=
WAIT_FOR_TIMEOUT_SECONDS=180
# Optional. When COMPOSE_PROFILES=vector, you may include milvus wait targets here.
WAIT_FOR_HOSTS=
WAIT_FOR_URLS=
FORWARDED_ALLOW_IPS=127.0.0.1
TRUSTED_HOSTS=["your-domain.com","www.your-domain.com","127.0.0.1","localhost"]

CORS_ALLOWED_ORIGINS=["https://your-domain.com","http://your-domain.com"]
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

DATABASE_URL=postgresql+asyncpg://postgres:change-this-password@localhost:5432/agentic

STORAGE_DIR=./storage
RAW_FILE_DIR=./storage/raw
ALLOWED_EXTENSIONS=[".pdf",".txt",".md",".docx",".pptx",".xlsx",".xls",".csv",".json",".xml",".html",".htm",".epub"]
MAX_FILE_SIZE=10485760

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_PATH=
EMBEDDING_CACHE_DIR=./storage/model_cache/sentence_transformers
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_PRELOAD_ON_STARTUP=false
RERANKER_ENABLED=false
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_PATH=
RERANKER_CACHE_DIR=./storage/model_cache/reranker
RERANKER_LOCAL_FILES_ONLY=false
RERANKER_PRELOAD_ON_STARTUP=false
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_TIMEOUT=600
HF_TOKEN=
VECTOR_BACKEND=milvus
GRAPH_BACKEND=neo4j
# Empty lets Docker Compose use http://milvus:19530 inside containers.
# For local non-Docker runs, app config defaults to http://127.0.0.1:19530.
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=document_chunks
MILVUS_INDEX_TYPE=FLAT
MILVUS_METRIC_TYPE=IP
MILVUS_SEARCH_PARAMS={"metric_type":"IP"}
MILVUS_CONSISTENCY_LEVEL=Strong
MILVUS_DROP_OLD=false
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-in-production
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=20
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474

# Supported: qwen, mimo, kimi, glm, deepseek.
# LLM_API_KEY is a generic override; provider-specific keys below are also supported.
LLM_PROVIDER=deepseek
LLM_API_KEY=
DASHSCOPE_API_KEY=
MIMO_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
# Leave LLM_BASE_URL and LLM_MODEL_NAME blank to use the provider defaults.
LLM_BASE_URL=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0.0

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=agentic
POSTGRES_PORT=5432

REDIS_PORT=6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_INDEX_QUEUE=document_index
CELERY_WORKER_CONCURRENCY=1
CELERY_LOG_LEVEL=INFO

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_CPU_LIMIT=1.0
MILVUS_MEMORY_LIMIT=2g

INDEX_VECTOR_BATCH_SIZE=64
RETRIEVAL_VECTOR_RECALL_K=12
RETRIEVAL_KEYWORD_RECALL_K=12
RETRIEVAL_MEMORY_RECALL_K=8
RETRIEVAL_RERANK_CANDIDATE_K=20
RETRIEVAL_CONTEXT_BUDGET_CHARS=4000
RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX=10
INDEX_SUBMIT_RATE_LIMIT_MAX=20
CHAT_QUERY_RATE_LIMIT_MAX=30

EXTERNAL_RETRY_MAX_ATTEMPTS=3
EXTERNAL_RETRY_BASE_DELAY_SECONDS=0.5
EXTERNAL_RETRY_MAX_DELAY_SECONDS=4.0

CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
