{
  "name": "mneme-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0 --config vite.config.mjs --configLoader native",
    "dev:embed": "node scripts/prebuild-check.mjs && vite build --watch --config vite.config.mjs --configLoader native",
    "build": "node scripts/prebuild-check.mjs && node scripts/build.mjs",
    "preview": "vite preview --config vite.config.mjs --configLoader native",
    "clean": "rm -rf dist server.js",
    "lint": "vue-tsc --noEmit",
    "test:e2e": "playwright test",
    "dev:preview": "vite --mode preview --port=3000 --host=0.0.0.0 --config vite.config.mjs --configLoader native"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vue-tsc": "^2.2.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "@google/genai": false,
    "@google/genai@1.52.0": false,
    "protobufjs": false
  }
}
